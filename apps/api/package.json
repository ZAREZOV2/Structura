{
  "name": "@structura/api",
  "license": "Apache-2.0",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "module": "src/index.ts",
  "exports": {
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun --env-file=../../.env test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env run src/db/migrate.ts",
    "db:push": "bun --env-file=../../.env x drizzle-kit push",
    "db:studio": "bun --env-file=../../.env x drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/jwt": "^1.2.0",
    "@elysiajs/swagger": "^1.2.0",
    "@structura/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "elysia": "^1.2.10",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.30.1"
  }
}
