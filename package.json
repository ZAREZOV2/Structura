{
  "name": "structura",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @structura/api dev",
    "dev:web": "bun run --filter @structura/web dev",
    "build": "bun run --filter '*' build",
    "build:web": "bun run --filter @structura/web build",
    "deploy:web": "wrangler deploy",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun run --filter @structura/api test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "db:generate": "bun run --filter @structura/api db:generate",
    "db:migrate": "bun run --filter @structura/api db:migrate",
    "db:studio": "bun run --filter @structura/api db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.14",
    "typescript": "^5.7.3",
    "wrangler": "^3.99.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
